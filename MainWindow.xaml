<Window x:Class="QiLiaoReply.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="欠料表处理工具 v2.15" Height="700" Width="960"
        WindowStartupLocation="CenterScreen" FontFamily="Microsoft YaHei, Segoe UI, sans-serif">
    <Window.Resources>
        <!-- 主题色：白色基底 + 粉紫渐变 -->
        <Color x:Key="PrimaryColor">#A855F7</Color>
        <Color x:Key="PrimaryHoverColor">#C084FC</Color>
        <Color x:Key="AccentColor">#EC4899</Color>
        <Color x:Key="AccentHoverColor">#F472B6</Color>
        <Color x:Key="BgColor">#FAF5FF</Color>
        <Color x:Key="CardColor">#FFFFFF</Color>
        <Color x:Key="BorderColor">#EBD3F5</Color>
        <Color x:Key="TextColor">#2E1065</Color>
        <Color x:Key="MutedColor">#8B6FA8</Color>
        <Color x:Key="InputColor">#FFFFFF</Color>
        <Color x:Key="TabHoverColor">#F3E8FF</Color>
        <Color x:Key="LogBgColor">#F6ECFF</Color>
        <Color x:Key="LogTextColor">#5B21B6</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="{DynamicResource PrimaryHoverColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentHover" Color="{DynamicResource AccentHoverColor}"/>
        <SolidColorBrush x:Key="BgBrush" Color="{DynamicResource BgColor}"/>
        <SolidColorBrush x:Key="CardBrush" Color="{DynamicResource CardColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}"/>
        <SolidColorBrush x:Key="MutedBrush" Color="{DynamicResource MutedColor}"/>
        <SolidColorBrush x:Key="InputBrush" Color="{DynamicResource InputColor}"/>
        <SolidColorBrush x:Key="TabHoverBrush" Color="{DynamicResource TabHoverColor}"/>
        <SolidColorBrush x:Key="LogBgBrush" Color="{DynamicResource LogBgColor}"/>
        <SolidColorBrush x:Key="LogTextBrush" Color="{DynamicResource LogTextColor}"/>

        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EC4899" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="RoundButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="9" Padding="{TemplateBinding Padding}" RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.98" ScaleY="0.98"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource RoundButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="9" Padding="{TemplateBinding Padding}" RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.98" ScaleY="0.98"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 卡片标题 -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,3" Margin="0,0,4,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource TabHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 头部 -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="❀" FontSize="22" Foreground="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="欠料表处理工具" FontSize="19" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="v2.15" FontSize="12" Foreground="#FCE7F3" Margin="12,0,0,0" VerticalAlignment="Bottom" Padding="0,0,0,3"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="18,16,18,0" Background="Transparent" BorderThickness="0">
            <!-- 导出 -->
            <TabItem Header="导出（按供应商拆分回复单）">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="导出设置" Style="{StaticResource CardTitle}"/>
                                <Label Content="欠料表文件"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox x:Name="ExpFileBox" IsReadOnly="True" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="选择文件" Click="ExpBrowse_Click" Style="{StaticResource RoundButton}"/>
                                </Grid>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <Label Content="采购员筛选（可选，留空=全部）"/>
                                        <TextBox x:Name="ExpPersonBox" ToolTip="按采购员列（U/Z）筛选；留空则导出全部外购/外协供应商"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Label Content="判定列（自动加载）" Grid.Column="0"/>
                                            <Button Grid.Column="1" Content="刷新" Click="ExpRefreshCols_Click" Style="{StaticResource RoundButton}" Padding="10,3" FontSize="11" Margin="0,0,0,2"/>
                                        </Grid>
                                        <ComboBox x:Name="ExpJudgeCombo" DisplayMemberPath="Display" ToolTip="从源表表头中选择判定列（值&lt;0 视为欠料）"/>
                                    </StackPanel>
                                </Grid>
                                <Label Content="类别（手动选择：外购 / 外协）"/>
                                <ComboBox x:Name="ExpCatCombo" Margin="0,0,0,4" ToolTip="手动选择本次导出类别：外购 或 外协。程序按 W 列（Y=外协 / N=外购）筛选对应明细；选「全部」则自动区分并分目录。"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,18,0,0">
                                    <Button Content="开始导出" Click="ExpRun_Click" Style="{StaticResource AccentButton}" Margin="0,0,12,0"/>
                                    <Button x:Name="ExpOpenBtn" Content="打开输出文件夹" Click="ExpOpen_Click" Style="{StaticResource RoundButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 回填 -->
            <TabItem Header="回填（回复单写回原表）">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="回填设置" Style="{StaticResource CardTitle}"/>
                                <Label Content="原欠料表文件"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox x:Name="BfOrigBox" IsReadOnly="True" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="选择文件" Click="BfOrigBrowse_Click" Style="{StaticResource RoundButton}"/>
                                </Grid>
                                <Label Content="供应商回复单（可多选）"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox x:Name="BfReplyBox" IsReadOnly="True" Margin="0,0,8,0" TextWrapping="Wrap" Height="56" VerticalScrollBarVisibility="Auto"/>
                                    <Button Grid.Column="1" Content="选择文件" Click="BfReplyBrowse_Click" Style="{StaticResource RoundButton}" VerticalAlignment="Top"/>
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Label Content="目标列（默认：采购交期回复）" Grid.Column="0"/>
                                            <Button Grid.Column="1" Content="刷新" Click="BfRefreshCols_Click" Style="{StaticResource RoundButton}" Padding="10,3" FontSize="11" Margin="0,0,0,2"/>
                                        </Grid>
                                        <ComboBox x:Name="BfTargetCombo" DisplayMemberPath="Display" ToolTip="从原欠料表表头中选择要写回复内容的列（默认自动选中「采购交期回复」列）"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Label Content="采购员姓名（回填未使用，仅占位）"/>
                                        <TextBox x:Name="BfPersonBox"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,18,0,0">
                                    <Button Content="开始回填" Click="BfRun_Click" Style="{StaticResource AccentButton}" Margin="0,0,12,0"/>
                                    <Button x:Name="BfOpenBtn" Content="打开回填结果" Click="BfOpen_Click" Style="{StaticResource RoundButton}" Visibility="Collapsed"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Expander Grid.Row="2" Margin="18,4,18,14" Header="处理日志" IsExpanded="True" Foreground="{DynamicResource MutedBrush}">
            <Border Background="{DynamicResource LogBgBrush}" CornerRadius="8" Height="130">
                <ListBox x:Name="LogBox" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource LogTextBrush}" Background="Transparent" BorderThickness="0"/>
            </Border>
        </Expander>
    </Grid>
</Window>
